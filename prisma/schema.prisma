generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Agency (Multi-tenant root) ───────────────────────────────────────────────

model Agency {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logoUrl         String?
  primaryColor    String   @default("#E8610A")
  secondaryColor  String   @default("#1A1A2E")
  plan            String   @default("STARTER") // STARTER | PRO | ENTERPRISE
  isActive        Boolean  @default(true)
  // Billing / fiscal info
  billingName     String?
  billingRnc      String?
  billingAddress  String?
  billingEmail    String?
  billingPhone    String?
  // Exchange rates
  exchangeRateDOP Float    @default(62)
  exchangeRateUSD Float    @default(1)
  // Mayoristas (JSON array of strings)
  mayoristas      String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users                User[]
  contacts             Contact[]
  opportunities        Opportunity[]
  invoices             Invoice[]
  supplierOrders       SupplierOrder[]
  groupBlocks          GroupBlock[]
  tasks                Task[]
  paymentLogs          PaymentLog[]
  paymentMethodConfigs PaymentMethodConfig[]
  pipelineStages       PipelineStage[]
  credits              Credit[]
  expenses             Expense[]
  socialAccounts       SocialAccount[]
  campaigns            Campaign[]
  salesGoals           SalesGoal[]
  automationRules      AutomationRule[]
  mediaAssets          MediaAsset[]
  appConfigs           AppConfig[]
  aiConversations      AiConversation[]
  budgetItems          BudgetItem[]
  workflowDefs         WorkflowDef[]
  securityLogs         SecurityLog[]
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  agencyId      String?
  agency        Agency?   @relation(fields: [agencyId], references: [id])
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(VENTAS)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  accounts         Account[]
  sessions         Session[]
  leads            Contact[]        @relation("AssignedAgent")
  opportunities    Opportunity[]
  invoices         Invoice[]
  interactions     Interaction[]
  commissionRate   CommissionRate?
  tasksAssigned    Task[]           @relation("TaskAssignee")
  tasksCreated     Task[]           @relation("TaskCreator")
  paymentLogs      PaymentLog[]
  securityLogs     SecurityLog[]
}

model CommissionRate {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rate       Float    @default(5)
  type       String   @default("AGENTE")
  updatedAt  DateTime @updatedAt
}

enum Role {
  SUPERADMIN
  ADMIN
  VENTAS
  CONTENIDO
  CONTABLE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Pipeline Stages ──────────────────────────────────────────────────────────

model PipelineStage {
  id            String        @id @default(cuid())
  agencyId      String?
  agency        Agency?       @relation(fields: [agencyId], references: [id])
  name          String
  order         Int
  color         String        @default("#E8610A")
  isDefault     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  opportunities Opportunity[]
}

// ─── Leads / Contacts ────────────────────────────────────────────────────────

model Contact {
  id           String   @id @default(cuid())
  agencyId     String?
  agency       Agency?  @relation(fields: [agencyId], references: [id])
  name         String
  phone        String?
  email        String?
  socialHandle String?
  channel      Channel
  tags         String   @default("[]")
  notes        String?
  agentId      String?
  agent        User?    @relation("AssignedAgent", fields: [agentId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  interactions  Interaction[]
  opportunities Opportunity[]
  tasks         Task[]
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  TIKTOK
  MESSENGER
  DIRECTO
  OTRO
}

model Interaction {
  id         String   @id @default(cuid())
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel    Channel
  content    String
  sentBy     String?
  isInternal Boolean  @default(false)
  agentId    String?
  agent      User?    @relation(fields: [agentId], references: [id])
  createdAt  DateTime @default(now())
}

// ─── Opportunities / Pipeline ─────────────────────────────────────────────────

model Opportunity {
  id              String        @id @default(cuid())
  agencyId        String?
  agency          Agency?       @relation(fields: [agencyId], references: [id])
  contactId       String
  contact         Contact       @relation(fields: [contactId], references: [id])
  stageId         String
  stage           PipelineStage @relation(fields: [stageId], references: [id])
  agentId         String?
  agent           User?         @relation(fields: [agentId], references: [id])
  destination     String?
  mayorista       String?
  travelStart     DateTime?
  travelEnd       DateTime?
  checkIn         DateTime?
  checkOut        DateTime?
  estimatedValue  Float?
  currency        Currency      @default(DOP)
  isInternational Boolean       @default(false)
  intlChecklist   String        @default("{}")
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  quotes   Quote[]
  invoices Invoice[]
  tasks    Task[]
}

enum Currency {
  DOP
  USD
}

// ─── Quotes ──────────────────────────────────────────────────────────────────

enum QuoteTipo {
  PLATAFORMA
  BLOQUEO
}

model Quote {
  id            String       @id @default(cuid())
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  label         String       @default("Cotización 1")
  tipo          QuoteTipo    @default(PLATAFORMA)
  mayorista     String
  hotelName     String
  description   String?
  checkIn       DateTime?
  checkOut      DateTime?
  nights        Int?
  adults        Int          @default(1)
  children      Int          @default(0)
  costPrice     Float
  salePrice     Float
  currency      Currency     @default(USD)
  exchangeRate  Float        @default(62)
  isSelected    Boolean      @default(false)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ─── Invoices (Clientes) ──────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  agencyId      String?
  agency        Agency?       @relation(fields: [agencyId], references: [id])
  number        String        @unique
  type          InvoiceType   @default(PROFORMA)
  ncfNumber     String?
  ncfType       String?
  opportunityId String?
  opportunity   Opportunity?  @relation(fields: [opportunityId], references: [id])
  clientName    String
  clientRnc     String?
  clientEmail   String?
  clientPhone   String?
  currency      Currency      @default(DOP)
  exchangeRate  Float         @default(62)
  subtotal      Float
  itbis         Float         @default(0)
  total         Float
  status        PaymentStatus @default(PENDIENTE)
  paidAt        DateTime?
  notes         String?
  agentId       String?
  agent         User?         @relation(fields: [agentId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items          InvoiceItem[]
  supplierOrders SupplierOrder[]
  credits        Credit[]
}

enum InvoiceType {
  NCF
  PROFORMA
  RECIBO
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  PARCIAL
  CANCELADO
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  unitPrice   Float
  total       Float
}

// ─── Supplier Orders (Mayoristas) ────────────────────────────────────────────

model SupplierOrder {
  id          String        @id @default(cuid())
  agencyId    String?
  agency      Agency?       @relation(fields: [agencyId], references: [id])
  invoiceId   String?
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id])
  mayorista   String
  description String
  amount      Float
  currency    Currency      @default(DOP)
  status      PaymentStatus @default(PENDIENTE)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ─── Group Blocks ─────────────────────────────────────────────────────────────

model GroupBlock {
  id              String     @id @default(cuid())
  agencyId        String?
  agency          Agency?    @relation(fields: [agencyId], references: [id])
  name            String
  hotel           String
  mayorista       String
  destination     String
  checkIn         DateTime
  checkOut        DateTime
  totalRooms      Int
  soldRooms       Int        @default(0)
  paymentDeadline DateTime?
  pricePerPax     Float
  currency        Currency   @default(DOP)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  passengers GroupPassenger[]
}

model GroupPassenger {
  id           String     @id @default(cuid())
  groupBlockId String
  groupBlock   GroupBlock @relation(fields: [groupBlockId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  email        String?
  roomType     String?
  amountPaid   Float      @default(0)
  totalDue     Float
  notes        String?
  createdAt    DateTime   @default(now())
}

// ─── App Config ───────────────────────────────────────────────────────────────

model AppConfig {
  id        String   @id @default(cuid())
  agencyId  String?
  agency    Agency?  @relation(fields: [agencyId], references: [id])
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([agencyId, key])
}

// ─── Social Accounts ─────────────────────────────────────────────────────────

model SocialAccount {
  id           String   @id @default(cuid())
  agencyId     String?
  agency       Agency?  @relation(fields: [agencyId], references: [id])
  platform     String
  accountName  String
  accountId    String?
  accessToken  String?
  status       String   @default("PENDING")
  avatarUrl    String?
  followers    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts        PostDraft[]
  metrics      SocialMetric[]
}

// ─── Media Library ────────────────────────────────────────────────────────────

model MediaAsset {
  id          String   @id @default(cuid())
  agencyId    String?
  agency      Agency?  @relation(fields: [agencyId], references: [id])
  name        String
  type        String
  url         String
  size        Int?
  width       Int?
  height      Int?
  duration    Int?
  tags        String   @default("[]")
  notes       String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

// ─── Post Drafts & Schedule ───────────────────────────────────────────────────

model PostDraft {
  id              String         @id @default(cuid())
  socialAccountId String?
  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id])
  platform        String
  postType        String
  caption         String?
  mediaUrls       String         @default("[]")
  hashtags        String?
  status          String         @default("DRAFT")
  scheduledAt     DateTime?
  publishedAt     DateTime?
  collaborators   String         @default("[]")
  campaignId      String?
  campaign        Campaign?      @relation(fields: [campaignId], references: [id])
  reach           Int?
  impressions     Int?
  engagement      Int?
  likes           Int?
  comments        Int?
  shares          Int?
  saves           Int?
  leadsGenerated  Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ─── Automation Rules ─────────────────────────────────────────────────────────

model AutomationRule {
  id          String   @id @default(cuid())
  agencyId    String?
  agency      Agency?  @relation(fields: [agencyId], references: [id])
  name        String
  active      Boolean  @default(true)
  platform    String
  trigger     String
  conditions  String
  actions     String
  executions  Int      @default(0)
  lastRun     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        AutomationLog[]
}

model AutomationLog {
  id           String         @id @default(cuid())
  ruleId       String
  rule         AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  triggeredBy  String?
  platform     String
  actionsRun   String
  leadCreated  Boolean        @default(false)
  createdAt    DateTime       @default(now())
}

// ─── Campaigns (Ads) ─────────────────────────────────────────────────────────

model Campaign {
  id             String   @id @default(cuid())
  agencyId       String?
  agency         Agency?  @relation(fields: [agencyId], references: [id])
  name           String
  platform       String
  externalId     String?
  status         String   @default("ACTIVE")
  objective      String?
  startDate      DateTime?
  endDate        DateTime?
  budget         Float    @default(0)
  currency       String   @default("USD")
  spent          Float    @default(0)
  reach          Int      @default(0)
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  leads          Int      @default(0)
  conversions    Int      @default(0)
  revenue        Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  posts          PostDraft[]
  leadSources    CampaignLead[]
}

model CampaignLead {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  contactId   String?
  source      String
  platform    String
  createdAt   DateTime @default(now())
}

// ─── Social Metrics ───────────────────────────────────────────────────────────

model SocialMetric {
  id              String         @id @default(cuid())
  socialAccountId String
  socialAccount   SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  date            DateTime
  followers       Int            @default(0)
  reach           Int            @default(0)
  impressions     Int            @default(0)
  engagement      Int            @default(0)
  profileViews    Int            @default(0)
  createdAt       DateTime       @default(now())

  @@unique([socialAccountId, date])
}

// ─── Sales Goals ─────────────────────────────────────────────────────────────

model SalesGoal {
  id        String   @id @default(cuid())
  agencyId  String?
  agency    Agency?  @relation(fields: [agencyId], references: [id])
  month     String
  userId    String?
  target    Float
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, month, userId])
}

// ─── Business Expenses ────────────────────────────────────────────────────────

model Expense {
  id            String   @id @default(cuid())
  agencyId      String?
  agency        Agency?  @relation(fields: [agencyId], references: [id])
  date          DateTime @default(now())
  category      String
  description   String
  amount        Float
  currency      Currency @default(DOP)
  paymentMethod String   @default("EFECTIVO")
  receiptUrl    String?
  notes         String?
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Credits ──────────────────────────────────────────────────────────────────

model Credit {
  id          String   @id @default(cuid())
  agencyId    String?
  agency      Agency?  @relation(fields: [agencyId], references: [id])
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  mayorista   String
  description String
  amount      Float
  currency    Currency @default(USD)
  status      String   @default("PENDIENTE")
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Tasks & Reminders ────────────────────────────────────────────────────────

model Task {
  id            String       @id @default(cuid())
  agencyId      String?
  agency        Agency?      @relation(fields: [agencyId], references: [id])
  title         String
  description   String?
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  assignedTo    String?
  assignee      User?        @relation("TaskAssignee", fields: [assignedTo], references: [id])
  createdBy     String?
  creator       User?        @relation("TaskCreator", fields: [createdBy], references: [id])
  dueDate       DateTime?
  reminderAt    DateTime?
  priority      String       @default("NORMAL")
  status        String       @default("PENDIENTE")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ─── Payment Audit Log ────────────────────────────────────────────────────────

model PaymentLog {
  id          String   @id @default(cuid())
  agencyId    String?
  agency      Agency?  @relation(fields: [agencyId], references: [id])
  entityType  String
  entityId    String
  action      String
  fromValue   String?
  toValue     String?
  notes       String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

// ─── Configurable Payment Methods ─────────────────────────────────────────────

model PaymentMethodConfig {
  id          String   @id @default(cuid())
  agencyId    String?
  agency      Agency?  @relation(fields: [agencyId], references: [id])
  name        String
  type        String   @default("TRANSFERENCIA")
  bankName    String?
  accountNum  String?
  description String?
  currency    String   @default("DOP")
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── AI Conversations ─────────────────────────────────────────────────────────

model AiConversation {
  id        String    @id @default(cuid())
  agencyId  String?
  agency    Agency?   @relation(fields: [agencyId], references: [id])
  userId    String
  title     String?
  messages  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── Annual Budget ─────────────────────────────────────────────────────────────

model BudgetItem {
  id        String   @id @default(cuid())
  agencyId  String?
  agency    Agency?  @relation(fields: [agencyId], references: [id])
  year      Int
  month     Int      // 1-12
  category  String   // VENTAS | MARKETING | OPERACION | COMISIONES | OTRO
  label     String?
  target    Float    @default(0)
  currency  String   @default("DOP")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, year, month, category])
}

// ─── Visual Workflows ─────────────────────────────────────────────────────────

model WorkflowDef {
  id          String   @id @default(cuid())
  agencyId    String?
  agency      Agency?  @relation(fields: [agencyId], references: [id])
  name        String
  description String?
  trigger     String   @default("LEAD_CREATED") // LEAD_CREATED | STAGE_CHANGED | INVOICE_PAID | MANUAL
  nodes       String   @default("[]")           // JSON array of WorkflowNode
  edges       String   @default("[]")           // JSON array of connections
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Security Logs ────────────────────────────────────────────────────────────

model SecurityLog {
  id        String   @id @default(cuid())
  agencyId  String?
  agency    Agency?  @relation(fields: [agencyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  event     String   // LOGIN_OK | LOGIN_FAIL | LOGOUT | SESSION_REVOKED | PASSWORD_CHANGED | 2FA_ENABLED
  email     String?
  ip        String?
  userAgent String?
  metadata  String?  // JSON
  createdAt DateTime @default(now())
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}
